# Perch — Environment Variables
#
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git — it's in .gitignore.
#
# All variables must be prefixed with VITE_ so Vite injects them
# into the client bundle at build time via import.meta.env.VITE_*

# ── Supabase ──────────────────────────────────────────────────────────────────
# Both values are safe to expose in the client — RLS enforces access control.
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Admin panel ───────────────────────────────────────────────────────────────
# Plain-text password for the /admin route gate (Phase 1 only).
# Replace with Supabase Auth in Phase 2.
# Keep this long, random, and private.
VITE_ADMIN_PASSWORD=change_me_to_a_strong_password
